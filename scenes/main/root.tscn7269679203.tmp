[sub_resource type="ShaderMaterial" id="ShaderMaterial_3xqdj"]
shader = ExtResource("4_3xqdj")
shader_parameter/preview = false
shader_parameter/preview_texture = ExtResource("12_386mo")
shader_parameter/levels = 16.0
shader_parameter/viewport_resolution = Vector2(640, 480)
shader_parameter/virtual_resolution = Vector2(320, 240)
shader_parameter/dither_strength = 0.06

[sub_resource type="GDScript" id="GDScript_386mo"]
script/source = "extends ColorRect

var current_level_in = 1.0
func levels_fade_in():
	while current_level_in <= 16.0:
		material.set(\"shader_parameter/levels\", current_level_in)
		current_level_in += 1.0
		await get_tree().create_timer(0.1).timeout
	current_level_in = 1.0

var current_level_out = 16.0
func levels_fade_out():
	while current_level_out >= 2.0:
		material.set(\"shader_parameter/levels\", current_level_out)
		current_level_out -= 1.0
		
		await get_tree().create_timer(0.1).timeout
	current_level_out = 16.0
"

